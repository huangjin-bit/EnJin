import asyncio
import time
from typing import Optional, List
from dataclasses import dataclass
import httpx
import json
import random
import logging

import config

logger = logging.getLogger(__name__)


@dataclass
class Proxy:
    url: str
    score: int = 100
    last_check: float = 0
    fail_count: int = 0
    success_count: int = 0
    avg_response_time: float = 0

    def to_dict(self) -> dict:
        return {
            "url": self.url,
            "score": self.score,
            "last_check": self.last_check,
            "fail_count": self.fail_count,
            "success_count": self.success_count,
            "avg_response_time": self.avg_response_time,
        }


class ProxyPool:
    def __init__(self):
        self.redis_client = None
        self.proxies: List[Proxy] = []
        self._lock = asyncio.Lock()
        if config.PROXY_POOL_ENABLED:
            self._init_redis()
            self._load_proxies()

    def _init_redis(self):
        try:
            import redis
            self.redis_client = redis.Redis(
                host=config.REDIS_HOST,
                port=config.REDIS_PORT,
                db=config.REDIS_DB,
                password=config.REDIS_PASSWORD,
                decode_responses=True,
            )
        except Exception as e:
            logger.warning(f"Redis connection failed, proxy persistence disabled: {e}")
            self.redis_client = None

    def _load_proxies(self):
        for url in getattr(config, "PROXY_URLS", []):
            self.proxies.append(Proxy(url=url))

    async def get_proxy(self) -> Optional[Proxy]:
        async with self._lock:
            if not self.proxies:
                return None
            valid_proxies = [p for p in self.proxies if p.score >= config.PROXY_MIN_SCORE]
            if not valid_proxies:
                return None
            return random.choice(valid_proxies)

    async def release_proxy(self, proxy: Proxy, success: bool, response_time: float = 0):
        async with self._lock:
            if success:
                proxy.success_count += 1
                proxy.avg_response_time = (
                    (proxy.avg_response_time * (proxy.success_count - 1) + response_time)
                    / proxy.success_count
                )
                proxy.score = min(100, proxy.score + 5)
            else:
                proxy.fail_count += 1
                proxy.score = max(0, proxy.score - 20)

            proxy.last_check = time.time()
            self._save_proxy(proxy)

    def _save_proxy(self, proxy: Proxy):
        if self.redis_client is None:
            return
        try:
            key = f"proxy:{proxy.url}"
            self.redis_client.set(key, json.dumps(proxy.to_dict()))
        except Exception as e:
            logger.warning(f"Failed to save proxy to Redis: {e}")

    async def check_proxy(self, proxy: Proxy) -> bool:
        try:
            async with httpx.AsyncClient(timeout=10) as client:
                response = await client.get("http://httpbin.org/ip")
                return response.status_code == 200
        except Exception:
            return False

    async def health_check(self):
        while True:
            await asyncio.sleep(config.PROXY_CHECK_INTERVAL)
            for proxy in self.proxies:
                is_healthy = await self.check_proxy(proxy)
                await self.release_proxy(proxy, is_healthy)


_proxy_pool: Optional[ProxyPool] = None


def get_proxy_pool() -> ProxyPool:
    global _proxy_pool
    if _proxy_pool is None:
        _proxy_pool = ProxyPool()
    return _proxy_pool
