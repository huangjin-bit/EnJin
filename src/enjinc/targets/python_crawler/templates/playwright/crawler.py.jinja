import asyncio
from typing import List, Optional, Callable, Any
from dataclasses import dataclass
from playwright.async_api import async_playwright, Page, Browser, BrowserContext, Response
import logging

import config

logger = logging.getLogger(__name__)


@dataclass
class PlaywrightResponse:
    url: str
    content: str
    status: int
    headers: dict


class PlaywrightCrawler:
    def __init__(
        self,
        headless: bool = True,
        user_agent: str = None,
        viewport_width: int = 1920,
        viewport_height: int = 1080,
    ):
        self.headless = headless
        self.user_agent = user_agent or config.DEFAULT_HEADERS.get("User-Agent")
        self.viewport = {"width": viewport_width, "height": viewport_height}

        self.playwright = None
        self.browser: Optional[Browser] = None
        self.context: Optional[BrowserContext] = None

        self.stats = {
            "pages_loaded": 0,
            "success": 0,
            "failed": 0,
        }

    async def __aenter__(self):
        await self.start()
        return self

    async def __aexit__(self, exc_type, exc_val, exc_tb):
        await self.close()

    async def start(self):
        self.playwright = await async_playwright().start()
        self.browser = await self.playwright.chromium.launch(headless=self.headless)
        self.context = await self.browser.new_context(
            user_agent=self.user_agent,
            viewport=self.viewport,
            ignore_https_errors=True,
        )

    async def close(self):
        if self.context:
            await self.context.close()
        if self.browser:
            await self.browser.close()
        if self.playwright:
            await self.playwright.stop()

        logger.info(
            f"[Playwright] Finished. "
            f"Pages: {self.stats['pages_loaded']}, "
            f"Success: {self.stats['success']}, "
            f"Failed: {self.stats['failed']}"
        )

    async def fetch(self, url: str) -> Optional[PlaywrightResponse]:
        try:
            page = await self.context.new_page()
            response = await page.goto(url, wait_until="networkidle")

            content = await page.content()
            status = response.status if response else 0

            await page.close()

            self.stats["pages_loaded"] += 1
            self.stats["success"] += 1

            return PlaywrightResponse(
                url=url,
                content=content,
                status=status,
                headers=dict(response.headers) if response else {},
            )

        except Exception as e:
            logger.error(f"Playwright fetch failed: {url} - {e}")
            self.stats["failed"] += 1
            return None

    async def fetch_with_screenshot(self, url: str, screenshot_path: str = None) -> Optional[PlaywrightResponse]:
        try:
            page = await self.context.new_page()
            response = await page.goto(url, wait_until="networkidle")

            if screenshot_path:
                await page.screenshot(path=screenshot_path, full_page=True)

            content = await page.content()
            status = response.status if response else 0

            await page.close()

            self.stats["pages_loaded"] += 1
            self.stats["success"] += 1

            return PlaywrightResponse(
                url=url,
                content=content,
                status=status,
                headers=dict(response.headers) if response else {},
            )

        except Exception as e:
            logger.error(f"Playwright fetch with screenshot failed: {url} - {e}")
            self.stats["failed"] += 1
            return None

    async def scrape_with_selector(self, url: str, selectors: List[str]) -> Optional[dict]:
        try:
            page = await self.context.new_page()
            await page.goto(url, wait_until="networkidle")

            data = {}
            for selector in selectors:
                if ":" in selector:
                    name, sel = selector.split(":", 1)
                    elements = await page.query_selector_all(sel)
                    data[name] = [await element.text_content() for element in elements]

            await page.close()
            self.stats["success"] += 1

            return data

        except Exception as e:
            logger.error(f"Playwright scrape failed: {url} - {e}")
            self.stats["failed"] += 1
            return None

    async def fill_form_and_submit(
        self,
        url: str,
        form_data: dict,
        submit_selector: str,
    ) -> Optional[PlaywrightResponse]:
        try:
            page = await self.context.new_page()
            await page.goto(url, wait_until="networkidle")

            for selector, value in form_data.items():
                await page.fill(selector, value)

            await page.click(submit_selector)
            await page.wait_for_load_state("networkidle")

            content = await page.content()

            await page.close()
            self.stats["success"] += 1

            return PlaywrightResponse(
                url=url,
                content=content,
                status=200,
                headers={},
            )

        except Exception as e:
            logger.error(f"Playwright form submission failed: {url} - {e}")
            self.stats["failed"] += 1
            return None
