package {{ pkg }}.interfaces.assembler;

import {{ pkg }}.domain.entity.{{ struct.name }};
{% if use_dto %}
import {{ pkg }}.interfaces.dto.request.{{ struct.name }}CreateRequest;
import {{ pkg }}.interfaces.dto.request.{{ struct.name }}UpdateRequest;
import {{ pkg }}.interfaces.dto.response.{{ struct.name }}Response;
{% endif %}
{% if use_vo %}
import {{ pkg }}.interfaces.vo.{{ struct.name }}VO;
{% endif %}

/**
 * {{ struct.name }} Assembler - Entity <-> DTO/VO converter
 */
public class {{ struct.name }}Assembler {

{% if use_dto %}
    public static {{ struct.name }} toEntity({{ struct.name }}CreateRequest request) {
        {{ struct.name }} entity = new {{ struct.name }}();
{% for field in struct.fields %}
{% set ns = namespace(is_primary=false) %}
{% for anno in field.annotations %}
{% if anno.name == 'primary' %}{% set ns.is_primary = true %}{% endif %}
{% endfor %}
{% if not ns.is_primary %}
        entity.set{{ field.name | snake_to_pascal }}(request.get{{ field.name | snake_to_pascal }}());
{% endif %}
{% endfor %}
        return entity;
    }

    public static {{ struct.name }}Response toResponse({{ struct.name }} entity) {
        {{ struct.name }}Response response = new {{ struct.name }}Response();
{% for field in struct.fields %}
{% if field.name not in sensitive_fields %}
        response.set{{ field.name | snake_to_pascal }}(entity.get{{ field.name | snake_to_pascal }}());
{% endif %}
{% endfor %}
        return response;
    }
{% endif %}
{% if use_vo %}

    public static {{ struct.name }}VO toVO({{ struct.name }} entity) {
        {{ struct.name }}VO vo = new {{ struct.name }}VO();
{% for field in struct.fields %}
{% if field.name not in sensitive_fields %}
        vo.set{{ field.name | snake_to_pascal }}(entity.get{{ field.name | snake_to_pascal }}());
{% endif %}
{% endfor %}
        return vo;
    }
{% endif %}
}
