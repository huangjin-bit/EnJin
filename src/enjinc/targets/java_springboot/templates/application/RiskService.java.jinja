    // ==================== 风控档案 ====================

    /**
     * 获取风控档案
     */
    public RiskProfile getRiskProfile(Long userId) {
        RiskProfile profile = riskProfileMapper.selectByUserId(userId);
        if (profile == null) {
            profile = RiskProfile.builder()
                    .userId(userId)
                    .totalScore(0)
                    .riskLevel("low")
                    .loginFailCount(0)
                    .orderCount(0)
                    .paymentCount(0)
                    .blockedCount(0)
                    .reviewedCount(0)
                    .tags("")
                    .build();
            riskProfileMapper.insert(profile);
        }
        return profile;
    }

    /**
     * 更新风控档案
     */
    public RiskProfile updateRiskProfile(Long userId, String riskLevel, Integer scoreDelta, String operationType) {
        RiskProfile profile = getRiskProfile(userId);
        
        profile.setTotalScore(Math.max(0, profile.getTotalScore() + scoreDelta));
        profile.setRiskLevel(riskLevel);
        profile.setLastRiskTime(LocalDateTime.now());
        
        switch (operationType) {
            case "login_fail" -> profile.setLoginFailCount(profile.getLoginFailCount() + 1);
            case "order_created" -> profile.setOrderCount(profile.getOrderCount() + 1);
            case "blocked" -> profile.setBlockedCount(profile.getBlockedCount() + 1);
            case "reviewed" -> profile.setReviewedCount(profile.getReviewedCount() + 1);
        }
        
        riskProfileMapper.updateById(profile);
        return profile;
    }

    // ==================== 预警管理 ====================

    /**
     * 触发风控预警
     */
    public RiskAlert triggerRiskAlert(String alertLevel, String alertType, Long userId, Long orderId,
                                       String title, String content) {
        String alertCode = "ALT" + System.currentTimeMillis();
        
        RiskAlert alert = RiskAlert.builder()
                .alertCode(alertCode)
                .alertLevel(alertLevel)
                .alertType(alertType)
                .userId(userId)
                .orderId(orderId)
                .title(title)
                .content(content)
                .status("pending")
                .build();
        
        riskAlertMapper.insert(alert);
        log.warn("触发风控预警: {} - {}", alertCode, title);
        
        return alert;
    }

    /**
     * 获取待处理预警
     */
    public List<RiskAlert> getPendingAlerts(String alertType, Integer limit) {
        return riskAlertMapper.selectPendingByType(alertType, limit);
    }

    /**
     * 处理预警
     */
    public boolean resolveAlert(String alertCode, String handler, String resolution) {
        RiskAlert alert = riskAlertMapper.selectByAlertCode(alertCode);
        if (alert == null) return false;
        
        alert.setStatus("resolved");
        alert.setHandler(handler);
        alert.setResolvedAt(LocalDateTime.now());
        riskAlertMapper.updateById(alert);
        
        return true;
    }

    // ==================== 设备指纹 ====================

    /**
     * 注册设备指纹
     */
    public DeviceFingerprint registerDeviceFingerprint(String deviceId, String deviceType,
                                                       String browser, String os, String ipAddress) {
        DeviceFingerprint fp = DeviceFingerprint.builder()
                .deviceId(deviceId)
                .deviceType(deviceType)
                .browser(browser)
                .os(os)
                .ipAddress(ipAddress)
                .riskScore(0)
                .lastSeen(LocalDateTime.now())
                .tags("")
                .build();
        
        deviceFingerprintMapper.insertOrUpdate(fp);
        return fp;
    }

    /**
     * 评估设备风险
     */
    public RiskDecision evaluateDeviceRisk(String deviceId, String ipAddress) {
        DeviceFingerprint fp = deviceFingerprintMapper.selectByDeviceId(deviceId);
        
        if (fp == null) {
            return RiskDecision.builder()
                    .decision("allow")
                    .riskLevel("medium")
                    .riskScore(30)
                    .hitRules(List.of("NEW_DEVICE"))
                    .suggestion("新设备，建议监控")
                    .build();
        }

        int score = fp.getRiskScore();
        
        // IP变更检测
        if (!fp.getIpAddress().equals(ipAddress)) {
            score += 20;
        }

        // 模拟器检测
        if (isEmulator(fp)) {
            score += 40;
        }

        return RiskDecision.builder()
                .decision(makeDecision(score))
                .riskLevel(getRiskLevel(score))
                .riskScore(score)
                .hitRules(score > 30 ? List.of("DEVICE_ANOMALY") : Collections.emptyList())
                .suggestion(score > 50 ? "设备异常" : "设备正常")
                .build();
    }

    // ==================== 规则引擎 ====================

    /**
     * 执行风控规则
     */
    public List<RuleResult> executeRiskRules(String eventType, Long userId, String context) {
        List<RiskRule> rules = riskRuleMapper.selectByEventType(eventType);
        List<RuleResult> results = new ArrayList<>();
        
        for (RiskRule rule : rules) {
            if (!Boolean.TRUE.equals(rule.getEnabled())) continue;
            
            boolean hit = evaluateRule(rule, userId, context);
            results.add(RuleResult.builder()
                    .ruleCode(rule.getRuleCode())
                    .ruleName(rule.getRuleName())
                    .hit(hit)
                    .score(hit ? rule.getScoreWeight() : 0)
                    .action(rule.getAction())
                    .build());
        }
        
        return results;
    }

