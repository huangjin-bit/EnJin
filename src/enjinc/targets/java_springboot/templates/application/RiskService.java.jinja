    // ==================== 黑名单管理 ====================

    /**
     * 检查黑名单
     */
    public BlacklistResult checkBlacklist(String blacklistType, String blacklistValue) {
        RiskBlacklist record = riskBlacklistMapper.selectByTypeAndValue(blacklistType, blacklistValue);
        boolean hit = record != null && 
            (record.getExpiresAt() == null || record.getExpiresAt().isAfter(LocalDateTime.now()));
        
        return BlacklistResult.builder()
                .hit(hit)
                .record(record)
                .reason(hit ? record.getReason() : "不在黑名单中")
                .build();
    }

    /**
     * 添加黑名单
     */
    public boolean addToBlacklist(String blacklistType, String blacklistValue, 
                                  String reason, String riskLevel, Integer expiresDays, String operator) {
        RiskBlacklist blacklist = RiskBlacklist.builder()
                .blacklistType(blacklistType)
                .blacklistValue(blacklistValue)
                .reason(reason)
                .riskLevel(riskLevel)
                .expiresAt(expiresDays != null ? LocalDateTime.now().plusDays(expiresDays) : null)
                .createdBy(operator)
                .build();
        
        return riskBlacklistMapper.insert(blacklist) > 0;
    }

    /**
     * 移除黑名单
     */
    public boolean removeFromBlacklist(String blacklistType, String blacklistValue, String operator) {
        return riskBlacklistMapper.deleteByTypeAndValue(blacklistType, blacklistValue) > 0;
    }

