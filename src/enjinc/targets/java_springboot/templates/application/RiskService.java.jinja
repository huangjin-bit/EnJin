                                            String paymentMethod, String cardBin, String ipAddress) {
        log.info("评估支付风险: userId={}, amount={}, method={}", userId, paymentAmount, paymentMethod);
        
        int score = 0;
        List<String> hitRules = new ArrayList<>();

        // 信用卡风控
        if ("credit_card".equals(paymentMethod)) {
            // 盗卡检测
            RiskDecision stolenCardResult = detectStolenCard(userId, cardBin, "****", ipAddress);
            if (stolenCardResult.isHit()) {
                score += 60;
                hitRules.add("STOLEN_CARD");
            }
        }

        // 可疑金额
        if (paymentAmount > 10000) {
            score += 20;
            hitRules.add("HIGH_PAYMENT_AMOUNT");
        }

        // IP风险
        if (checkBlacklist("ip", ipAddress).isHit()) {
            score += 40;
            hitRules.add("IP_BLACKLIST");
        }

        String riskLevel = getRiskLevel(score);
        String decision = makeDecision(score);

        // 可疑支付触发预警
        if (score > 40) {
            triggerRiskAlert("warning", "payment", userId, null,
                "可疑支付", String.format("支付金额: %.2f, 方式: %s", paymentAmount, paymentMethod));
        }

        return RiskDecision.builder()
                .decision(decision)
                .riskLevel(riskLevel)
                .riskScore(score)
                .hitRules(hitRules)
                .suggestion(score > 50 ? "建议人工审核" : "支付正常")
                .build();
    }

