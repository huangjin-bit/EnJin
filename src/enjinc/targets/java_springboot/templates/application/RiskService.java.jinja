    private String getRiskLevel(int score) {
        if (score >= 80) return "critical";
        if (score >= 60) return "high";
        if (score >= 30) return "medium";
        return "low";
    }

    private String makeDecision(int score) {
        if (score >= 80) return "block";
        if (score >= 60) return "review";
        if (score >= 30) return "alert";
        return "allow";
    }

    private String getSuggestion(int score) {
        if (score >= 80) return "直接拦截";
        if (score >= 60) return "建议人工审核";
        if (score >= 30) return "建议验证码验证";
        return "正常通过";
    }

    private void saveRiskEvent(String eventType, Long userId, Long orderId, Long paymentId,
                                String riskLevel, List<String> triggeredRules, int riskScore,
                                String decision, String ipAddress, String deviceFingerprint) {
        RiskEvent event = RiskEvent.builder()
                .eventId("EVT" + System.currentTimeMillis())
                .eventType(eventType)
                .userId(userId)
                .orderId(orderId)
                .paymentId(paymentId)
                .riskLevel(riskLevel)
                .triggeredRules(String.join(",", triggeredRules))
                .riskScore(riskScore)
                .decision(decision)
                .detail("")
                .ipAddress(ipAddress)
                .deviceFingerprint(deviceFingerprint)
                .build();
        
        riskEventMapper.insert(event);
    }

