    // ==================== 用户风控 ====================

    /**
     * 评估用户注册风险
     */
    public RiskDecision evaluateUserRegisterRisk(String username, String email, String phone,
                                                  String ipAddress, String deviceFingerprint) {
        log.info("评估用户注册风险: username={}, email={}, ip={}", username, email, ipAddress);
        
        // 检查白名单
        WhitelistResult wlResult = checkWhitelist("user", username);
        if (wlResult.isHit()) {
            return RiskDecision.builder()
                    .decision("allow")
                    .riskLevel("low")
                    .riskScore(0)
                    .hitRules(Collections.emptyList())
                    .suggestion("白名单用户")
                    .build();
        }

        // 检查黑名单
        BlacklistResult blResult = checkBlacklist("user", username);
        if (blResult.isHit()) {
            return RiskDecision.builder()
                    .decision("block")
                    .riskLevel("critical")
                    .riskScore(100)
                    .hitRules(List.of("BLACKLIST"))
                    .suggestion("用户已在黑名单")
                    .build();
        }

        // 检查设备指纹
        RiskDecision deviceRisk = evaluateDeviceRisk(deviceFingerprint, ipAddress);
        
        // 计算综合风险评分
        int totalScore = calculateRiskScore(1L, "register", 
            String.format("{\"device_score\":%d,\"ip\":\"%s\"}", 
                deviceRisk.getRiskScore(), ipAddress));

        // 决策
        String decision = makeDecision(totalScore);
        String riskLevel = getRiskLevel(totalScore);

        // 记录风险事件
        saveRiskEvent("register", 1L, null, null, riskLevel, 
            List.of("DEVICE_CHECK", "IP_CHECK"), totalScore, decision, ipAddress, deviceFingerprint);

        return RiskDecision.builder()
                .decision(decision)
                .riskLevel(riskLevel)
                .riskScore(totalScore)
                .hitRules(List.of("DEVICE_RISK"))
                .suggestion("注册风险评估完成")
                .build();
    }

    /**
     * 评估用户登录风险
     */
    public RiskDecision evaluateUserLoginRisk(Long userId, String ipAddress, 
                                               String deviceFingerprint, String loginStatus) {
        log.info("评估用户登录风险: userId={}, ip={}, status={}", userId, ipAddress, loginStatus);
        
        // 获取用户风控档案
        RiskProfile profile = getRiskProfile(userId);
        
        // 检查异地登录
        boolean isRemoteLogin = checkRemoteLogin(userId, ipAddress);
        
        // 检查暴力破解
        boolean isBruteForce = profile.getLoginFailCount() > 5;
        
        // 计算风险评分
        int score = 0;
        List<String> hitRules = new ArrayList<>();
        
        if (isRemoteLogin) {
            score += 30;
            hitRules.add("REMOTE_LOGIN");
        }
        if (isBruteForce) {
            score += 40;
            hitRules.add("BRUTE_FORCE");
        }
        if (checkBlacklist("ip", ipAddress).isHit()) {
            score += 50;
            hitRules.add("IP_BLACKLIST");
        }
        
        String riskLevel = getRiskLevel(score);
        String decision = makeDecision(score);

        // 更新风控档案
        if ("success".equals(loginStatus)) {
            updateRiskProfile(userId, riskLevel, -5, "login_success");
        } else {
            updateRiskProfile(userId, riskLevel, 10, "login_fail");
        }

        return RiskDecision.builder()
                .decision(decision)
                .riskLevel(riskLevel)
                .riskScore(score)
                .hitRules(hitRules)
                .suggestion(score > 50 ? "建议验证码二次验证" : "登录正常")
                .build();
    }

    // ==================== 订单风控 ====================

    /**
     * 评估订单风险
     */
    public RiskDecision evaluateOrderRisk(Long userId, Double orderAmount, Integer productCount,
                                           String addressHash, String ipAddress, String deviceFingerprint) {
        log.info("评估订单风险: userId={}, amount={}, count={}", userId, orderAmount, productCount);
        
        int score = 0;
        List<String> hitRules = new ArrayList<>();

        // 大额订单检查
        if (orderAmount > 5000) {
            score += 20;
            hitRules.add("HIGH_AMOUNT");
        }
        if (orderAmount > 10000) {
            score += 30;
            hitRules.add("VERY_HIGH_AMOUNT");
        }

        // 高频下单检查
        RiskProfile profile = getRiskProfile(userId);
        if (profile.getOrderCount() > 10) {
            score += 15;
            hitRules.add("HIGH_FREQUENCY");
        }

        // 地址异常检查
        if (isAddressAnomaly(userId, addressHash)) {
            score += 25;
            hitRules.add("ADDRESS_ANOMALY");
        }

        // 设备风险
        RiskDecision deviceRisk = evaluateDeviceRisk(deviceFingerprint, ipAddress);
        score += deviceRisk.getRiskScore() / 5;
        if (deviceRisk.getRiskScore() > 50) {
            hitRules.add("DEVICE_RISK");
        }

        // 黑名单检查
        if (checkBlacklist("ip", ipAddress).isHit()) {
            score += 50;
            hitRules.add("IP_BLACKLIST");
        }

        String riskLevel = getRiskLevel(score);
        String decision = makeDecision(score);

        // 高价值订单触发预警
        if (orderAmount > 10000) {
            triggerRiskAlert("warning", "order", userId, null,
                "高价值订单", String.format("订单金额: %.2f, 用户: %d", orderAmount, userId));
        }

        return RiskDecision.builder()
                .decision(decision)
                .riskLevel(riskLevel)
                .riskScore(score)
                .hitRules(hitRules)
                .suggestion(score > 60 ? "建议人工审核" : "订单正常")
                .build();
    }

    /**
     * 评估高价值订单风险
     */
    public RiskDecision evaluateHighValueOrderRisk(Long orderId, Long userId, Double amount) {
        log.info("评估高价值订单风险: orderId={}, userId={}, amount={}", orderId, userId, amount);
        
        int score = 30; // 基础分
        List<String> hitRules = List.of("HIGH_VALUE_ORDER");

        // 超高金额
        if (amount > 50000) {
            score += 40;
            hitRules.add("VERY_VERY_HIGH_AMOUNT");
        } else if (amount > 20000) {
            score += 20;
            hitRules.add("VERY_HIGH_AMOUNT");
        }

        // 新用户大额
        RiskProfile profile = getRiskProfile(userId);
        if (profile.getOrderCount() < 3 && amount > 5000) {
            score += 30;
            hitRules.add("NEW_USER_HIGH_AMOUNT");
        }

        String riskLevel = getRiskLevel(score);
        
        // 高价值订单必须审核
        String decision = score > 60 ? "review" : "allow";

        // 触发预警
        triggerRiskAlert("danger", "order", userId, orderId,
            "高价值订单风控", String.format("订单金额: %.2f, 风险评分: %d", amount, score));

        return RiskDecision.builder()
                .decision(decision)
                .riskLevel(riskLevel)
                .riskScore(score)
                .hitRules(hitRules)
                .suggestion("高价值订单建议人工审核")
                .build();
    }

