    // ==================== 实时决策 ====================

    /**
     * 综合风控决策
     */
    public RiskDecision makeRiskDecision(String eventType, Long userId, Long orderId,
                                          Double amount, String ipAddress, String deviceFingerprint) {
        log.info("综合风控决策: event={}, userId={}, orderId={}, amount={}", 
            eventType, userId, orderId, amount);
        
        int totalScore = 0;
        List<String> allHitRules = new ArrayList<>();

        // 执行所有适用规则
        List<RuleResult> ruleResults = executeRiskRules(eventType, userId, "{}");
        for (RuleResult rr : ruleResults) {
            if (rr.isHit()) {
                totalScore += rr.getScore();
                allHitRules.add(rr.getRuleCode());
            }
        }

        // 上下文风险加成
        if (amount != null && amount > 5000) {
            totalScore += 15;
            allHitRules.add("HIGH_AMOUNT");
        }

        String riskLevel = getRiskLevel(totalScore);
        String decision = makeDecision(totalScore);

        return RiskDecision.builder()
                .decision(decision)
                .riskLevel(riskLevel)
                .riskScore(totalScore)
                .hitRules(allHitRules)
                .suggestion(getSuggestion(totalScore))
                .build();
    }

