-- ================================================================
-- V2__init_risk_control.sql
-- 风控系统数据库初始化脚本
-- ================================================================

-- 风控规则表
CREATE TABLE risk_rules (
    id BIGSERIAL PRIMARY KEY,
    rule_code VARCHAR(100) UNIQUE NOT NULL,
    rule_name VARCHAR(200) NOT NULL,
    rule_type VARCHAR(50) NOT NULL COMMENT 'user, order, payment, coupon, device',
    risk_level VARCHAR(20) NOT NULL COMMENT 'low, medium, high, critical',
    condition_expr TEXT NOT NULL COMMENT '规则条件表达式',
    action VARCHAR(20) NOT NULL COMMENT 'allow, block, review, alert',
    score_weight INT DEFAULT 0,
    enabled BOOLEAN DEFAULT TRUE,
    start_time TIMESTAMP,
    end_time TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_risk_rules_type ON risk_rules(rule_type);
CREATE INDEX idx_risk_rules_enabled ON risk_rules(enabled);

-- 风控事件表
CREATE TABLE risk_events (
    id BIGSERIAL PRIMARY KEY,
    event_id VARCHAR(100) UNIQUE NOT NULL,
    event_type VARCHAR(50) NOT NULL COMMENT 'register, login, create_order, payment, claim_coupon, review',
    user_id BIGINT,
    order_id BIGINT,
    payment_id BIGINT,
    risk_level VARCHAR(20) NOT NULL,
    triggered_rules TEXT COMMENT '逗号分隔的规则代码',
    risk_score INT NOT NULL,
    decision VARCHAR(20) NOT NULL COMMENT 'allow, block, review, alert',
    detail TEXT,
    ip_address VARCHAR(50),
    device_fingerprint VARCHAR(200),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_risk_events_user ON risk_events(user_id);
CREATE INDEX idx_risk_events_order ON risk_events(order_id);
CREATE INDEX idx_risk_events_type ON risk_events(event_type);
CREATE INDEX idx_risk_events_level ON risk_events(risk_level);
CREATE INDEX idx_risk_events_created ON risk_events(created_at);

-- 用户风控档案表
CREATE TABLE risk_profiles (
    id BIGSERIAL PRIMARY KEY,
    user_id BIGINT UNIQUE NOT NULL REFERENCES users(id),
    total_score INT DEFAULT 0,
    risk_level VARCHAR(20) DEFAULT 'low',
    login_fail_count INT DEFAULT 0,
    order_count INT DEFAULT 0,
    payment_count INT DEFAULT 0,
    blocked_count INT DEFAULT 0,
    reviewed_count INT DEFAULT 0,
    last_risk_time TIMESTAMP,
    tags TEXT DEFAULT '',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_risk_profiles_user ON risk_profiles(user_id);
CREATE INDEX idx_risk_profiles_level ON risk_profiles(risk_level);

-- 黑名单表
CREATE TABLE risk_blacklist (
    id BIGSERIAL PRIMARY KEY,
    blacklist_type VARCHAR(50) NOT NULL COMMENT 'user, phone, email, ip, device, address',
    blacklist_value VARCHAR(500) NOT NULL,
    reason VARCHAR(500) NOT NULL,
    risk_level VARCHAR(20) NOT NULL,
    expires_at TIMESTAMP,
    created_by VARCHAR(100) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_risk_blacklist_type_value ON risk_blacklist(blacklist_type, blacklist_value);
CREATE INDEX idx_risk_blacklist_expires ON risk_blacklist(expires_at);

-- 白名单表
CREATE TABLE risk_whitelist (
    id BIGSERIAL PRIMARY KEY,
    whitelist_type VARCHAR(50) NOT NULL COMMENT 'user, phone, email, ip, device',
    whitelist_value VARCHAR(500) NOT NULL,
    reason VARCHAR(500) NOT NULL,
    expires_at TIMESTAMP,
    created_by VARCHAR(100) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_risk_whitelist_type_value ON risk_whitelist(whitelist_type, whitelist_value);

-- 风控预警表
CREATE TABLE risk_alerts (
    id BIGSERIAL PRIMARY KEY,
    alert_code VARCHAR(100) UNIQUE NOT NULL,
    alert_level VARCHAR(20) NOT NULL COMMENT 'info, warning, danger, critical',
    alert_type VARCHAR(50) NOT NULL COMMENT 'user, order, payment, coupon, device',
    user_id BIGINT,
    order_id BIGINT,
    title VARCHAR(200) NOT NULL,
    content TEXT NOT NULL,
    status VARCHAR(20) DEFAULT 'pending' COMMENT 'pending, processing, resolved, ignored',
    handler VARCHAR(100),
    resolved_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_risk_alerts_user ON risk_alerts(user_id);
CREATE INDEX idx_risk_alerts_order ON risk_alerts(order_id);
CREATE INDEX idx_risk_alerts_status ON risk_alerts(status);
CREATE INDEX idx_risk_alerts_level ON risk_alerts(alert_level);
CREATE INDEX idx_risk_alerts_created ON risk_alerts(created_at);

-- 设备指纹表
CREATE TABLE device_fingerprints (
    id BIGSERIAL PRIMARY KEY,
    device_id VARCHAR(200) UNIQUE NOT NULL,
    device_type VARCHAR(100) NOT NULL,
    browser VARCHAR(100),
    os VARCHAR(100),
    ip_address VARCHAR(50) NOT NULL,
    risk_score INT DEFAULT 0,
    last_seen TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    tags TEXT DEFAULT '',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_device_fp_device_id ON device_fingerprints(device_id);
CREATE INDEX idx_device_fp_ip ON device_fingerprints(ip_address);

-- 敏感操作日志表
CREATE TABLE risk_operation_logs (
    id BIGSERIAL PRIMARY KEY,
    user_id BIGINT,
    operation_type VARCHAR(50) NOT NULL COMMENT 'register, login, order, payment, refund, coupon, review',
    operation_id VARCHAR(200) NOT NULL,
    before_status VARCHAR(50),
    after_status VARCHAR(50),
    risk_checked BOOLEAN DEFAULT FALSE,
    risk_decision VARCHAR(20),
    ip_address VARCHAR(50),
    user_agent VARCHAR(500),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_risk_ops_user ON risk_operation_logs(user_id);
CREATE INDEX idx_risk_ops_type ON risk_operation_logs(operation_type);
CREATE INDEX idx_risk_ops_created ON risk_operation_logs(created_at);

